CREATE PROCEDURE dbo.usp_GenerateJobScripts ( @JobDefinitionIds NVARCHAR(MAX) -- Example: '1,2,5' ) AS BEGIN SET NOCOUNT ON; ------------------------------------------------------------ -- Parse input IDs ------------------------------------------------------------ DECLARE @Ids TABLE (JOB_DEFINITION_ID INT PRIMARY KEY); INSERT INTO @Ids SELECT DISTINCT TRY_CAST(value AS INT) FROM STRING_SPLIT(@JobDefinitionIds, ',') WHERE TRY_CAST(value AS INT) IS NOT NULL; DECLARE @FinalScript NVARCHAR(MAX) = ''; ------------------------------------------------------------ -- HEADER ------------------------------------------------------------ SET @FinalScript = @FinalScript + ' /*================================================== JOB_DEFINITION INSERT SCRIPT ==================================================*/ SET IDENTITY_INSERT dbo.JOB_DEFINITION ON; GO '; ------------------------------------------------------------ -- JOB_DEFINITION SCRIPT ------------------------------------------------------------ DECLARE @JD_SCRIPT NVARCHAR(MAX); SELECT @JD_SCRIPT = STUFF( ( SELECT CHAR(13)+CHAR(10)+ ' IF EXISTS (SELECT 1 FROM dbo.JOB_DEFINITION WHERE JOB_DEFINITION_ID = ' + CAST(jd.JOB_DEFINITION_ID AS VARCHAR) + ') BEGIN PRINT ''JOB_DEFINITION_ID ' + CAST(jd.JOB_DEFINITION_ID AS VARCHAR) + ' already exists - skipping''; END ELSE BEGIN INSERT INTO dbo.JOB_DEFINITION ( JOB_DEFINITION_ID, job_name, job_command, WORKFLOW_TASK_NAME, ENABLED, SR_DEFINATION_NAME, BUSINESS_CALENDAR_ID, MODIFIED_BY, MODIFIED_DATE, EXPECTED_THRESHOLD, CREATE_DATE, CODE_VERSION_HANDLER ) VALUES ( ' + CAST(jd.JOB_DEFINITION_ID AS VARCHAR) + ', ''' + REPLACE(jd.job_name,'''','''''') + ''', ''' + REPLACE(jd.job_command,'''','''''') + ''', ' + CASE WHEN jd.WORKFLOW_TASK_NAME IS NULL THEN 'NULL' ELSE '''' + REPLACE(jd.WORKFLOW_TASK_NAME,'''','''''') + '''' END + ', ' + CASE WHEN jd.ENABLED IS NULL THEN 'NULL' ELSE CAST(jd.ENABLED AS VARCHAR) END + ', ' + CASE WHEN jd.SR_DEFINATION_NAME IS NULL THEN 'NULL' ELSE '''' + REPLACE(jd.SR_DEFINATION_NAME,'''','''''') + '''' END + ', ' + CASE WHEN jd.BUSINESS_CALENDAR_ID IS NULL THEN 'NULL' ELSE CAST(jd.BUSINESS_CALENDAR_ID AS VARCHAR) END + ', ' + CASE WHEN jd.MODIFIED_BY IS NULL THEN 'NULL' ELSE '''' + REPLACE(jd.MODIFIED_BY,'''','''''') + '''' END + ', GETDATE(), ' + CASE WHEN jd.EXPECTED_THRESHOLD IS NULL THEN 'NULL' ELSE CAST(jd.EXPECTED_THRESHOLD AS VARCHAR) END + ', ''' + CONVERT(VARCHAR(23), jd.CREATE_DATE,121) + ''', ' + CASE WHEN jd.CODE_VERSION_HANDLER IS NULL THEN 'NULL' ELSE '''' + REPLACE(jd.CODE_VERSION_HANDLER,'''','''''') + '''' END + ' ) END GO ' FROM dbo.JOB_DEFINITION jd JOIN @Ids i ON jd.JOB_DEFINITION_ID = i.JOB_DEFINITION_ID FOR XML PATH(''), TYPE ).value('.','NVARCHAR(MAX)') ,1,2,''); SET @FinalScript = @FinalScript + ISNULL(@JD_SCRIPT,''); SET @FinalScript = @FinalScript + ' SET IDENTITY_INSERT dbo.JOB_DEFINITION OFF; GO /*================================================== JOB_SCHEDULE INSERT SCRIPT ==================================================*/ SET IDENTITY_INSERT dbo.JOB_SCHEDULE ON; GO '; ------------------------------------------------------------ -- JOB_SCHEDULE SCRIPT ------------------------------------------------------------ DECLARE @JS_SCRIPT NVARCHAR(MAX); SELECT @JS_SCRIPT = STUFF( ( SELECT CHAR(13)+CHAR(10)+ ' IF EXISTS (SELECT 1 FROM dbo.JOB_SCHEDULE WHERE JOB_SCHEDULE_ID = ' + CAST(js.JOB_SCHEDULE_ID AS VARCHAR) + ') BEGIN PRINT ''JOB_SCHEDULE_ID ' + CAST(js.JOB_SCHEDULE_ID AS VARCHAR) + ' already exists - skipping''; END ELSE BEGIN INSERT INTO dbo.JOB_SCHEDULE ( JOB_SCHEDULE_ID, JOB_DEFINITION_ID, SERVER_NAME, SCHEDULE_TYPE, SCHEDULE, INSTANCE_COUNT, ENABLED, MODFIED_BY, MODIFIED_DATE, CREATE_DATE ) VALUES ( ' + CAST(js.JOB_SCHEDULE_ID AS VARCHAR) + ', ' + CAST(js.JOB_DEFINITION_ID AS VARCHAR) + ', ''' + REPLACE(js.SERVER_NAME,'''','''''') + ''', ''' + REPLACE(js.SCHEDULE_TYPE,'''','''''') + ''', ''' + REPLACE(js.SCHEDULE,'''','''''') + ''', ' + CAST(js.INSTANCE_COUNT AS VARCHAR) + ', ' + CASE WHEN js.ENABLED IS NULL THEN 'NULL' ELSE CAST(js.ENABLED AS VARCHAR) END + ', ' + CASE WHEN js.MODFIED_BY IS NULL THEN 'NULL' ELSE '''' + REPLACE(js.MODFIED_BY,'''','''''') + '''' END + ', GETDATE(), GETDATE() ) END GO ' FROM dbo.JOB_SCHEDULE js JOIN @Ids i ON js.JOB_DEFINITION_ID = i.JOB_DEFINITION_ID FOR XML PATH(''), TYPE ).value('.','NVARCHAR(MAX)') ,1,2,''); SET @FinalScript = @FinalScript + ISNULL(@JS_SCRIPT,''); SET @FinalScript = @FinalScript + ' SET IDENTITY_INSERT dbo.JOB_SCHEDULE OFF; GO '; ------------------------------------------------------------ -- RETURN FINAL SCRIPT ------------------------------------------------------------ SELECT @FinalScript AS GeneratedScript; END GO ``` --- # How to Run ```sql EXEC dbo.usp_GenerateJobScripts '1,2'; ``` The result will return **one column called `GeneratedScript`** containing a **properly formatted full migration script**. You can **copy the entire output and run it on another server**. --- # Example Output (Readable) ```sql SET IDENTITY_INSERT dbo.JOB_DEFINITION ON GO IF EXISTS (SELECT 1 FROM dbo.JOB_DEFINITION WHERE JOB_DEFINITION_ID = 1) BEGIN PRINT 'JOB_DEFINITION_ID 1 already exists - skipping' END ELSE BEGIN INSERT INTO dbo.JOB_DEFINITION (...) END GO ```
